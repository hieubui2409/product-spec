{
  "schema_version": "1.0",
  "skill": "cleanmatic:claude-pack",
  "scenarios": [
    {
      "id": "pack-product-spec-standalone",
      "description": "Pack cleanmatic:product-spec into a versioned tar.gz with deterministic SHA256.",
      "input": {
        "manifest": "eval/fixtures/minimal.manifest.yaml",
        "args": ["--version", "0.1.0", "--out", "/tmp/eval-out"]
      },
      "assertions": [
        "tarball file exists at /tmp/eval-out/claude-pack-0.1.0.tar.gz",
        "sidecar file exists at /tmp/eval-out/claude-pack-0.1.0.tar.gz.sha256",
        "MANIFEST.json has schema_version == '1.0'",
        "gzip header bytes [4:8] == 0x00000000",
        "no entry path contains '/.env', '/.git/', '/__pycache__/'",
        "second run produces identical SHA256"
      ]
    },
    {
      "id": "safety-scan-dirty-claude",
      "description": "safety_check on a repo containing .env + .git emits warn-level findings without exposing content.",
      "input": {
        "args": ["--root", "eval/fixtures/dirty-claude", "--scan", "."]
      },
      "assertions": [
        "exit code 0",
        "findings include check=='always_drop' rule contains 'exact:.env'",
        "findings include check=='always_drop' rule contains 'dir:.git'",
        "JSON output schema_version == '1.0'",
        "no file content echoed to stdout/stderr"
      ]
    },
    {
      "id": "interactive-dry-run-preview",
      "description": "Interactive answers → build_manifest --write → pack --dry-run preview.",
      "input": {
        "answers": "eval/fixtures/interactive-answers.json",
        "pack_args": ["--dry-run", "--compute-sha", "--json"]
      },
      "assertions": [
        "build_manifest --write exits 0",
        "generated YAML starts with '# Generated by cleanmatic:claude-pack'",
        "pack --dry-run does NOT create tar.gz file",
        "would_be_sha256 is a 64-char hex string",
        "file_count > 0"
      ]
    }
  ]
}
