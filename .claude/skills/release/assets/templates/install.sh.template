#!/usr/bin/env bash
# install.sh — recipient installer for {{BUNDLE_NAME}} v{{VERSION}}.
#
# Run from the extracted bundle directory. Installs the bundle contents
# (selected .claude/ artifacts PLUS any packed top-level files such as
# README.md/CLAUDE.md) into the target repo (default: pwd).
# Version-aware: detects stale/newer/same versions per skill and reports
# an action plan.
#
# Usage:
#   bash install.sh                       # install into current repo
#   TARGET_DIR=/path/to/repo bash install.sh
#   FORCE_OVERWRITE=1 bash install.sh     # overwrite existing (with timestamped backup)
#   RUN_HOOKS=1 bash install.sh           # also run per-skill install.sh hooks (opt-in)
#
# Per-skill hooks (e.g. .claude/skills/*/install.sh) are NOT run by default because
# they execute arbitrary code. Review them first, then re-run with RUN_HOOKS=1.

set -euo pipefail

BUNDLE_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
TARGET_DIR="${TARGET_DIR:-$PWD}"
FORCE_OVERWRITE="${FORCE_OVERWRITE:-0}"
RUN_HOOKS="${RUN_HOOKS:-0}"
BACKUP_TS="$(date -u +%Y%m%dT%H%M%SZ)"

MANIFEST_JSON="$BUNDLE_DIR/MANIFEST.json"
[ -f "$MANIFEST_JSON" ] || { echo "MANIFEST.json missing — corrupt bundle?" >&2; exit 1; }

# --- Helpers ---
log()  { echo "[{{BUNDLE_NAME}}] $*"; }
note() { echo "  $*"; }

# True when $1 is one of the two BLOCKING enforcement hooks. These are treated as
# KIT CODE on upgrade: a pre-config-gate copy (which blocks turn-end uncondition-
# ally once wired) is force-replaced with the config-gated bundle copy, unlike the
# read-only telemetry hooks which follow the generic skip-existing path. The `*`
# prefix tolerates the walk's `./`-prefixed relative paths.
is_enforcement_hook() {
    case "$1" in
        *.claude/hooks/memory_gap_hook.py|*.claude/hooks/product_spec_critique_nudge.py) return 0 ;;
        *) return 1 ;;
    esac
}

# Extract metadata.version from a SKILL.md frontmatter block.
# Returns empty string if absent or unparseable.
read_skill_version() {
    local skill_md="$1"
    [ -f "$skill_md" ] || { echo ""; return; }
    # Frontmatter block delimited by --- ... ---
    awk '
        /^---[[:space:]]*$/ { fm++; next }
        fm == 1 && /^[[:space:]]+version:[[:space:]]*"?([0-9]+\.[0-9]+\.[0-9]+[A-Za-z0-9.+-]*)"?/ {
            match($0, /[0-9]+\.[0-9]+\.[0-9]+[A-Za-z0-9.+-]*/);
            print substr($0, RSTART, RLENGTH);
            exit
        }
        fm >= 2 { exit }
    ' "$skill_md"
}

# semver_compare A B — full SemVer 2.0.0 precedence.
# Prints: -1 if A < B, 0 if A == B, 1 if A > B.
#
# Rules implemented:
#   1. Numeric major.minor.patch compared numerically left-to-right.
#   2. Pre-release is LOWER than the associated release (1.0.0-rc1 < 1.0.0).
#   3. Pre-release identifiers separated by "." compared left-to-right:
#      numeric identifiers compare numerically; alphanumeric compare ASCII-lexically;
#      numeric < alphanumeric (per spec §11.4.1.4).
#      Longer pre-release is higher when all prior identifiers are equal.
#   4. Build metadata ("+...") is IGNORED for precedence (§10).
semver_compare() {
    local a="$1" b="$2"
    # Force bytewise ordering for alphanumeric pre-release identifier comparisons.
    # SemVer §11.4.1.3 mandates ASCII-ordinal collation; under some locales the
    # shell's [[ < ]] operator uses LC_COLLATE instead, flipping case comparisons
    # (e.g. "RC" vs "rc").  Setting LC_ALL=C here is scoped to this function.
    local LC_ALL=C

    # Strip build metadata (everything after first "+")
    a="${a%%+*}"
    b="${b%%+*}"

    if [ "$a" = "$b" ]; then echo 0; return; fi

    # Split off pre-release suffix ("-...")
    local a_core="${a%%-*}" a_pre=""
    local b_core="${b%%-*}" b_pre=""
    [[ "$a" == *-* ]] && a_pre="${a#*-}"
    [[ "$b" == *-* ]] && b_pre="${b#*-}"

    # Compare numeric core (major.minor.patch) field by field
    local IFS_SAVE="$IFS"
    IFS='.'
    # shellcheck disable=SC2206
    local -a av=($a_core) bv=($b_core)
    IFS="$IFS_SAVE"

    local i
    for i in 0 1 2; do
        local ai="${av[$i]:-0}" bi="${bv[$i]:-0}"
        # Force base-10 so leading-zero fields (08, 09) are not parsed as
        # invalid octal by bash arithmetic — that would make both comparisons
        # error and fall through to echo 0 (OK SAME), silently skipping upgrades.
        if (( 10#${ai} < 10#${bi} )); then echo -1; return; fi
        if (( 10#${ai} > 10#${bi} )); then echo  1; return; fi
    done

    # Cores are equal — compare pre-release.
    # No pre-release > has pre-release (release > pre-release).
    if [ -z "$a_pre" ] && [ -z "$b_pre" ]; then echo 0; return; fi
    if [ -z "$a_pre" ] && [ -n "$b_pre" ]; then echo  1; return; fi  # A is release, B is pre
    if [ -n "$a_pre" ] && [ -z "$b_pre" ]; then echo -1; return; fi  # A is pre, B is release

    # Both have pre-release — compare identifier by identifier.
    IFS='.'
    # shellcheck disable=SC2206
    local -a ap=($a_pre) bp=($b_pre)
    IFS="$IFS_SAVE"

    local max_i=$(( ${#ap[@]} > ${#bp[@]} ? ${#ap[@]} : ${#bp[@]} ))
    for (( i=0; i<max_i; i++ )); do
        local ai="${ap[$i]:-}" bi="${bp[$i]:-}"
        # Shorter pre-release is lower when all prior identifiers equal
        if [ -z "$ai" ] && [ -n "$bi" ]; then echo -1; return; fi
        if [ -n "$ai" ] && [ -z "$bi" ]; then echo  1; return; fi
        # Both numeric?
        if [[ "$ai" =~ ^[0-9]+$ ]] && [[ "$bi" =~ ^[0-9]+$ ]]; then
            # Force base-10 to guard against leading-zero octal misparse.
            if (( 10#${ai} < 10#${bi} )); then echo -1; return; fi
            if (( 10#${ai} > 10#${bi} )); then echo  1; return; fi
        elif [[ "$ai" =~ ^[0-9]+$ ]]; then
            # Numeric identifier < alphanumeric identifier
            echo -1; return
        elif [[ "$bi" =~ ^[0-9]+$ ]]; then
            echo 1; return
        else
            # Both alphanumeric — ASCII lexical compare
            if [[ "$ai" < "$bi" ]]; then echo -1; return; fi
            if [[ "$ai" > "$bi" ]]; then echo  1; return; fi
        fi
    done

    echo 0
}

# --- Counters ---
ADDED=0
SKIPPED=0
OVERWROTE=0
STALE_KEPT=0   # stale skills kept because FORCE_OVERWRITE was not set
STALE_WROTE=0  # stale skills overwritten under FORCE_OVERWRITE
NEWER=0

# --- Per-skill version verdicts ---
# Computed once per skill slug from its SKILL.md, then applied to ALL files in
# that skill's directory. This prevents the split-brain scenario where SKILL.md
# is kept at NEWER but other files under the same skill are silently overwritten.
#
# Parallel arrays (bash-3.2-compatible; associative arrays via 'declare -A' require
# bash 4+ and are absent on macOS which ships bash 3.2 by default):
#   SKILL_VERDICT_SLUGS  — ordered list of skill slugs seen during compute
#   SKILL_VERDICT_VALUES — verdict for the slug at the same index ("SKIP"|"OVERWRITE"|"ADD")
# Lookup: _get_skill_verdict "$slug" prints the verdict (or "" when absent).
SKILL_VERDICT_SLUGS=()
SKILL_VERDICT_VALUES=()

_set_skill_verdict() {
    local slug="$1" verdict="$2"
    SKILL_VERDICT_SLUGS+=("$slug")
    SKILL_VERDICT_VALUES+=("$verdict")
}

_get_skill_verdict() {
    local slug="$1" i
    for i in "${!SKILL_VERDICT_SLUGS[@]}"; do
        if [ "${SKILL_VERDICT_SLUGS[$i]}" = "$slug" ]; then
            echo "${SKILL_VERDICT_VALUES[$i]}"
            return
        fi
    done
    echo ""
}

compute_skill_verdicts() {
    local bundle_skills="$BUNDLE_DIR/.claude/skills"
    [ -d "$bundle_skills" ] || return 0
    for skill_dir in "$bundle_skills"/*/; do
        [ -d "$skill_dir" ] || continue
        local slug="${skill_dir%/}"
        slug="${slug##*/}"
        local src_md="$skill_dir/SKILL.md"
        local dst_md="$TARGET_DIR/.claude/skills/$slug/SKILL.md"
        if [ -f "$dst_md" ] && [ -f "$src_md" ]; then
            local exist_v bundle_v cmp
            exist_v=$(read_skill_version "$dst_md")
            bundle_v=$(read_skill_version "$src_md")
            if [ -n "$exist_v" ] && [ -n "$bundle_v" ]; then
                cmp=$(semver_compare "$exist_v" "$bundle_v")
                case "$cmp" in
                    -1)
                        if [ "$FORCE_OVERWRITE" = "1" ]; then
                            note "[STALE] skill '$slug' ($exist_v → $bundle_v; overwriting)"
                            STALE_WROTE=$((STALE_WROTE+1))
                            _set_skill_verdict "$slug" "OVERWRITE"
                        else
                            note "[STALE] skill '$slug' ($exist_v → $bundle_v; set FORCE_OVERWRITE=1 to update)"
                            STALE_KEPT=$((STALE_KEPT+1))
                            _set_skill_verdict "$slug" "SKIP"
                        fi
                        ;;
                    0)
                        note "[OK SAME] skill '$slug' ($exist_v)"
                        _set_skill_verdict "$slug" "SKIP"
                        ;;
                    1)
                        note "[NEWER] skill '$slug' ($exist_v > $bundle_v; refusing downgrade)"
                        NEWER=$((NEWER+1))
                        _set_skill_verdict "$slug" "SKIP"
                        ;;
                esac
                continue
            elif [ -n "$exist_v" ] && [ -z "$bundle_v" ]; then
                # Existing install has a version but the bundle does not — ambiguous;
                # skip to avoid overwriting a potentially newer installed version.
                note "[UNKNOWN VERSION] skill '$slug' (installed: $exist_v; bundle version unreadable — skipping)"
                _set_skill_verdict "$slug" "SKIP"
                continue
            elif [ -z "$exist_v" ] && [ -n "$bundle_v" ]; then
                # Installed copy has no parseable version but bundle does — ambiguous;
                # skip to avoid accidentally downgrading an untagged manual install.
                note "[UNKNOWN VERSION] skill '$slug' (installed: unversioned; bundle: $bundle_v — skipping)"
                _set_skill_verdict "$slug" "SKIP"
                continue
            fi
            # Neither side has a parseable version — fall through to ADD (existing behavior).
        fi
        _set_skill_verdict "$slug" "ADD"
    done
}

# --- Walk .claude/ in bundle, mirror to target ---
log "Bundle: $BUNDLE_DIR"
log "Target: $TARGET_DIR"
log "Force overwrite: $FORCE_OVERWRITE"
echo ""

compute_skill_verdicts
echo ""

cd "$BUNDLE_DIR"
# Process substitution (not `find | while`) so counter increments survive —
# a piped `while` runs in a subshell and its variable updates are lost.
# LC_ALL=C ensures locale-stable bytewise sort, matching the builder's sort order.
while IFS= read -r REL; do
    # Defense-in-depth traversal guard (recipient-side).
    # The builder already validates arcnames, but we re-check here so a
    # manually crafted or corrupted bundle cannot escape $TARGET_DIR.
    # Parity: install.ps1 has an equivalent check — keep both lists in sync.
    case "$REL" in
        /*|*/../*|../*|*/..)
            note "[SKIP traversal] $REL"
            continue
            ;;
    esac

    SRC="$BUNDLE_DIR/$REL"
    DST="$TARGET_DIR/$REL"
    DST_DIR="$(dirname "$DST")"

    # Determine if this path belongs to a known skill slug.
    # Path form: .claude/skills/<slug>/...
    local_slug=""
    if [[ "$REL" =~ ^\.claude/skills/([^/]+)/ ]]; then
        local_slug="${BASH_REMATCH[1]}"
    fi

    # Apply the per-skill verdict when we have one.
    verdict=""
    if [ -n "$local_slug" ]; then
        verdict=$(_get_skill_verdict "$local_slug")
    fi
    if [ -n "$local_slug" ] && [ -n "$verdict" ]; then
        case "$verdict" in
            SKIP)
                # Skill version is OK SAME or NEWER — skip all files unconditionally.
                # (STALE + no FORCE_OVERWRITE also lands here.)
                SKIPPED=$((SKIPPED+1))
                continue
                ;;
            OVERWRITE)
                # STALE + FORCE_OVERWRITE — overwrite every file in the skill.
                if [ -f "$DST" ]; then
                    mkdir -p "$DST_DIR"
                    cp -f "$DST" "$DST.bak.$BACKUP_TS"
                    cp -f "$SRC" "$DST"
                    note "[OVERWRITE] $REL (backup: $DST.bak.$BACKUP_TS)"
                    OVERWROTE=$((OVERWROTE+1))
                else
                    mkdir -p "$DST_DIR"
                    cp "$SRC" "$DST"
                    note "[+] $REL"
                    ADDED=$((ADDED+1))
                fi
                continue
                ;;
            ADD)
                # Skill is new — fall through to the generic file logic below.
                ;;
        esac
    fi

    # Enforcement-hook upgrade safety (runs before the generic skip path; the
    # FORCE_OVERWRITE=1 branch below already overwrites-with-backup, so this only
    # governs the default no-force upgrade). A blocking enforcement hook that does
    # NOT call the config gate `hook_enabled` is a pre-config-gate copy: once the
    # registrar wires it, it blocks turn-end unconditionally for a PO who never
    # opted in. Replace it with the gated bundle copy (backup first). A gate-aware
    # copy that merely DIFFERS may be a deliberate PO edit — keep it, flag a
    # CONFLICT, and let FORCE_OVERWRITE=1 take the bundle (never blind-overwrite).
    if is_enforcement_hook "$REL" && [ -f "$DST" ] && [ "$FORCE_OVERWRITE" != "1" ]; then
        if ! grep -q 'hook_enabled' "$DST"; then
            mkdir -p "$DST_DIR"
            cp -f "$DST" "$DST.bak.$BACKUP_TS"
            cp -f "$SRC" "$DST"
            note "[SECURITY OVERWRITE] $REL (pre-config-gate hook replaced; backup: $DST.bak.$BACKUP_TS)"
            OVERWROTE=$((OVERWROTE+1))
            continue
        elif ! cmp -s "$SRC" "$DST"; then
            note "[CONFLICT] $REL (locally modified gate-aware hook kept; bundle NOT applied — FORCE_OVERWRITE=1 to take bundle)"
            SKIPPED=$((SKIPPED+1))
            continue
        fi
        # Identical gate-aware copy → fall through to the generic SKIP (idempotent).
    fi

    # Generic file logic (non-skill files, or new skill files with verdict=ADD).
    if [ -f "$DST" ]; then
        if [ "$FORCE_OVERWRITE" = "1" ]; then
            mkdir -p "$DST_DIR"
            cp -f "$DST" "$DST.bak.$BACKUP_TS"
            cp -f "$SRC" "$DST"
            note "[OVERWRITE] $REL (backup: $DST.bak.$BACKUP_TS)"
            OVERWROTE=$((OVERWROTE+1))
        else
            note "[SKIP] $REL (exists; FORCE_OVERWRITE=1 to replace)"
            SKIPPED=$((SKIPPED+1))
        fi
    else
        mkdir -p "$DST_DIR"
        cp "$SRC" "$DST"
        note "[+] $REL"
        ADDED=$((ADDED+1))
    fi
# Walk the whole bundle root so top-level files (README.md, CLAUDE.md, etc.)
# that were packed but have no .claude/ prefix are also installed.
# Installer metadata files (MANIFEST.json, INSTALL.md, install.sh, install.ps1)
# are excluded — they belong to the bundle, not to the recipient's repo.
# PARITY: install.ps1 excludes the same 4 names via $ExcludeNames — keep both
# lists in sync.
done < <(LC_ALL=C find . -type f -print | LC_ALL=C sort | grep -vE '^(./MANIFEST\.json|./INSTALL\.md|./install\.sh|./install\.ps1)$')

# --- Run per-skill install hooks (opt-in) ---
# These hooks execute arbitrary code on the recipient's machine.
# Default: skip. Pass RUN_HOOKS=1 to enable after reviewing the scripts.
echo ""
if [ "$RUN_HOOKS" = "1" ]; then
    log "Running per-skill install hooks (RUN_HOOKS=1)"
    LC_ALL=C find "$TARGET_DIR/.claude/skills" -maxdepth 2 -name install.sh -type f 2>/dev/null | LC_ALL=C sort | while IFS= read -r HOOK; do
        note "-> $HOOK"
        bash "$HOOK" || note "   ! exited non-zero (continuing)"
    done
else
    log "Skipping per-skill install hooks (set RUN_HOOKS=1 to enable)"
    log "Review .claude/skills/*/install.sh before enabling."
fi

# --- Enable telemetry hooks (usage & health observability) ---
# The bundle ships read-only telemetry hooks (cleanmatic:telemetry). Wire them into
# the recipient's settings.json so the lenses have data to read. The registrar is
# idempotent + upgrade-safe — it checks for existing entries and never double-registers.
# Non-fatal: a registration failure must never fail the install. Opt out anytime with:
#   python3 .claude/skills/telemetry/scripts/register_telemetry_hooks.py --remove
echo ""
REGISTRAR="$TARGET_DIR/.claude/skills/telemetry/scripts/register_telemetry_hooks.py"
if [ -f "$REGISTRAR" ]; then
    if command -v python3 >/dev/null 2>&1; then
        log "Enabling telemetry hooks (usage & health) in settings.json"
        if CLAUDE_PROJECT_DIR="$TARGET_DIR" python3 "$REGISTRAR"; then
            note "Telemetry enabled. Opt out: python3 .claude/skills/telemetry/scripts/register_telemetry_hooks.py --remove"
        else
            note "! telemetry registration skipped (non-fatal — register manually later)"
        fi
    else
        note "python3 not found — telemetry hooks left unregistered (run register_telemetry_hooks.py to enable)"
    fi
fi

# --- Gitignore: protect telemetry data from accidental commits ---
# The telemetry skill writes runtime data to .claude/telemetry/ — usage JSONL files
# that are local to the recipient's machine and should never be committed to source
# control. Append the entry to .gitignore if it is not already there (idempotent).
echo ""
GITIGNORE_FILE="$TARGET_DIR/.gitignore"
if ! grep -q '\.claude/telemetry/' "$GITIGNORE_FILE" 2>/dev/null; then
    # If the file exists and its last byte is NOT a newline, a bare append would
    # join the entry onto the final line (e.g. "node_modules.claude/telemetry/"):
    # the prior entry is corrupted AND telemetry stays un-ignored. Insert a
    # separating newline first. tail -c1 + command-substitution is portable to
    # bash 3.2 (no associative arrays / process-substitution needed here).
    if [ -s "$GITIGNORE_FILE" ] && [ -n "$(tail -c1 "$GITIGNORE_FILE")" ]; then
        printf '\n' >> "$GITIGNORE_FILE"
    fi
    printf '%s\n' '.claude/telemetry/' >> "$GITIGNORE_FILE"
    log "Added .claude/telemetry/ to .gitignore (prevents accidental commit of telemetry data)"
else
    log ".claude/telemetry/ already in .gitignore — skipping"
fi

# --- Summary ---
echo ""
log "Summary"
note "Added:           $ADDED"
note "Skipped:         $SKIPPED"
note "Overwrote:       $OVERWROTE"
note "Stale kept:      $STALE_KEPT"
note "Stale overwrote: $STALE_WROTE"
note "Newer kept:      $NEWER"
echo ""
log "Done. Invoke the bundled skills from Claude Code (e.g. type / in a Claude Code session to see available skills)."
