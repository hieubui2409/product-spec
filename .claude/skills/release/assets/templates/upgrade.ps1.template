# upgrade.ps1 — one-command 1.x -> 2.x upgrade for {{BUNDLE_NAME}} v{{VERSION}}.
#
# Sweeps legacy 1.x artifacts (spec-critique/, claude-pack/, old dev rules),
# force-installs the new bundle over the target, and runs migrate dry-run.
#
# Usage:
#   powershell -ExecutionPolicy Bypass -File .\upgrade.ps1
#   powershell -ExecutionPolicy Bypass -File .\upgrade.ps1 -TargetDir C:\repos\my-app
#   powershell -ExecutionPolicy Bypass -File .\upgrade.ps1 -Apply
#   powershell -ExecutionPolicy Bypass -File .\upgrade.ps1 -Rollback
#
# Safety contract (enforced by Python planner/apply, not this shell wrapper):
#   - Every removal is backed up to upgrade-backup-<timestamp>/ BEFORE deletion.
#   - A file differing from its pristine hash is KEPT (prompted), never blind-removed.
#   - Symlinks are unlinked only — never followed to external targets.
#   - Rule removals only activate when a 1.x legacy signature is present.
#   - migrate_metric_to_metrics is run DRY-RUN ONLY here. PO approval is a separate step.
#   - If any deletion step fails, the Python layer self-rolls-back (atomic).
#   - If Step 2 (install) or Step 3 (migrate) fails, the script auto-rolls-back the sweep.
#
# Requires: python (python3 or python) for the planner.

[CmdletBinding()]
param(
    [string]$TargetDir = (Get-Location).Path,
    [switch]$Apply,
    [switch]$Rollback
)

$ErrorActionPreference = "Stop"

$BundleDir = Split-Path -Parent $MyInvocation.MyCommand.Path
$Planner   = Join-Path $BundleDir "_upgrade\upgrade_planner.py"
$ApplyPy   = Join-Path $BundleDir "_upgrade\upgrade_apply.py"
$LegacyMap = Join-Path $BundleDir "_upgrade\legacy-map.json"

# ---------------------------------------------------------------------------
# Locate python
# ---------------------------------------------------------------------------
$Py = $null
foreach ($candidate in @("python3", "python")) {
    $found = Get-Command $candidate -ErrorAction SilentlyContinue
    if ($found) { $Py = $found.Source; break }
}
if (-not $Py) {
    Write-Error "[upgrade] ERROR: python3/python not found. Install Python 3 and re-run."
    exit 1
}

# Validate bundle payload
if (-not (Test-Path $Planner))   { Write-Error "[upgrade] ERROR: $Planner not found — corrupt bundle?"; exit 1 }
if (-not (Test-Path $LegacyMap)) { Write-Error "[upgrade] ERROR: $LegacyMap not found — corrupt bundle?"; exit 1 }

function Log($msg) { Write-Host "[upgrade] $msg" }

# ---------------------------------------------------------------------------
# --Rollback: restore from most recent upgrade-backup-* dir
# ---------------------------------------------------------------------------
if ($Rollback) {
    Log "Looking for most recent upgrade-backup-* in $TargetDir ..."
    $backups = Get-ChildItem -Path $TargetDir -Directory -Filter "upgrade-backup-*" -ErrorAction SilentlyContinue |
               Sort-Object Name
    if (-not $backups) {
        Write-Error "[upgrade] ERROR: No upgrade-backup-* directory found in $TargetDir"
        exit 1
    }
    $latestBackup = ($backups | Select-Object -Last 1).FullName
    Log "Rolling back from: $latestBackup"
    & $Py $ApplyPy --rollback $latestBackup
    Log "Rollback complete."
    exit 0
}

# ---------------------------------------------------------------------------
# Dry-run (default): print plan, write nothing
# ---------------------------------------------------------------------------
if (-not $Apply) {
    Log "DRY-RUN for {{BUNDLE_NAME}} v{{VERSION}}"
    Log "Target: $TargetDir"
    Write-Host ""
    & $Py $Planner --target $TargetDir --legacy-map $LegacyMap --dry-run
    Write-Host ""
    Log "No files changed. Re-run with -Apply to execute the upgrade."
    Log "  powershell -ExecutionPolicy Bypass -File .\upgrade.ps1 -Apply"
    exit 0
}

# ---------------------------------------------------------------------------
# -Apply: sweep legacy artifacts + force-install new bundle + migrate dry-run
# ---------------------------------------------------------------------------
Log "APPLY for {{BUNDLE_NAME}} v{{VERSION}}"
Log "Target:     $TargetDir"
Log "Bundle dir: $BundleDir"
Write-Host ""

# Step 1: Python planner+apply (atomic: self-rolls-back on failure)
Log "Step 1/3: Sweeping legacy 1.x artifacts ..."
& $Py $Planner --target $TargetDir --legacy-map $LegacyMap --apply
Write-Host ""

# Capture the backup dir the sweep just created (for auto-rollback if a later step fails).
$rollbackOnErr = (Get-ChildItem -Path $TargetDir -Directory -Filter "upgrade-backup-*" -ErrorAction SilentlyContinue |
                  Sort-Object Name | Select-Object -Last 1)

# Gitignore the backup artifacts.
$gi = Join-Path $TargetDir ".gitignore"
$giLine = 'upgrade-backup-*/'
if (-not (Test-Path $gi) -or -not (Select-String -Path $gi -SimpleMatch -Pattern $giLine -Quiet)) {
    Add-Content -Path $gi -Value $giLine
}

try {
    # Step 2: Force-install new bundle
    Log "Step 2/3: Installing {{BUNDLE_NAME}} v{{VERSION}} (force-overwrite) ..."
    $env:FORCE_OVERWRITE = "1"
    $InstallPs1 = Join-Path $BundleDir "install.ps1"
    & powershell -ExecutionPolicy Bypass -File $InstallPs1 -TargetDir $TargetDir -ForceOverwrite
    Write-Host ""

    # Step 3: Migrate dry-run only (NEVER --apply here)
    Log "Step 3/3: Checking for legacy metric: fields (dry-run only) ..."
    $MigrateScript = Join-Path $TargetDir ".claude\skills\product-spec\scripts\migrate_metric_to_metrics.py"
    if (Test-Path $MigrateScript) {
        try { & $Py $MigrateScript --root $TargetDir } catch { }
        Write-Host ""
        Log "NOTE: migrate_metric_to_metrics ran DRY-RUN ONLY above."
        Log "  If confirm_required is true, run the migration separately"
        Log "  with explicit PO approval (--confirmed-by and --date flags)."
        Log "  The upgrade script never applies migrate automatically."
    } else {
        Log "migrate_metric_to_metrics.py not found at expected path -- skipping."
    }
    Write-Host ""
} catch {
    Write-Host "[upgrade] FAILED — $_"
    if ($rollbackOnErr) {
        Write-Host "[upgrade] Auto-rolling back the legacy sweep from: $($rollbackOnErr.FullName)"
        & $Py $ApplyPy --rollback $rollbackOnErr.FullName
        Write-Host "[upgrade] Legacy restored. Re-running with -Apply is safe (idempotent)."
    }
    Remove-Item Env:\FORCE_OVERWRITE -ErrorAction SilentlyContinue
    exit 1
}

Remove-Item Env:\FORCE_OVERWRITE -ErrorAction SilentlyContinue

Log "Upgrade complete."
Log "To roll back: powershell -ExecutionPolicy Bypass -File .\upgrade.ps1 -Rollback"
