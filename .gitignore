.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# flutter
.dart_tool
build
GoogleService-Info.plist

repomix-output.xml
.serena/cache
screenshots/*
docs/screenshots/*
logs.txt
test-ck
__pycache__

# CK meta commands
prompt.md
ck.md

# Generated runtime layout for release/install smoke tests.
# We ignore everything under /.claude/ EXCEPT:
#  - /.claude/rules/  : repo-level rules Claude Code reads
#  - /.claude/skills/product-spec/  : this repo's authored skill
/.claude/*
!/.claude/rules/
!/.claude/skills/
/.claude/skills/*
!/.claude/skills/product-spec/
!/.claude/skills/product-spec/**
!/.claude/skills/claude-pack/
!/.claude/skills/claude-pack/**
!/.claude/skills/spec-critique/
!/.claude/skills/spec-critique/**
# Seed manifest for claude-pack (committed source-of-truth)
!/.claude/pack.manifest.yaml
# CK-framework artifacts committed so the repo self-packs reproducibly
!/.claude/agents/
!/.claude/agents/**
!/.claude/scripts/
!/.claude/scripts/**
!/.claude/schemas/
!/.claude/schemas/**
# /.claude/hooks/ holds ck-managed *.cjs (NOT this repo's) — keep them ignored,
# but track the one skill-owned hook so it commits and ships in the CI bundle.
!/.claude/hooks/
/.claude/hooks/*
!/.claude/hooks/memory_gap_hook.py
!/.claude/hooks/spec_critique_nudge.py
# Re-ignore Python cache + build artifacts inside tracked skills
/.claude/skills/product-spec/**/__pycache__/
/.claude/skills/product-spec/**/*.pyc
/.claude/skills/claude-pack/**/__pycache__/
/.claude/skills/claude-pack/**/*.pyc
/.claude/skills/claude-pack/dist/
/.claude/skills/spec-critique/**/__pycache__/
/.claude/skills/spec-critique/**/*.pyc
/.claude/scripts/**/__pycache__/
/.claude/scripts/**/*.pyc

# Local-only state inside tracked claude source
claude/agent-memory/
claude/hooks/.logs/
claude/session-state/latest.md
claude/session-state/archive/
claude/settings.bak.json
claude/skills/ai-multimodal/assets/demo-*.claude/session-state/*.tmp

# Gemini CLI settings (symlink to staged .claude/.mcp.json)
.gemini/settings.json
# Showoff/marketing assets (images, showcases)
assets/
# Exception: use-mcp ships a persistent tool catalog at assets/tools.json
!claude/skills/use-mcp/assets/
!claude/skills/use-mcp/assets/**
# Exception: product-spec ships templates + vendored Mermaid JS in assets/
!.claude/skills/product-spec/assets/
!.claude/skills/product-spec/assets/**
# Exception: claude-pack ships installer templates + manifest example in assets/
!.claude/skills/claude-pack/assets/
!.claude/skills/claude-pack/assets/**

# External repos for study/reference
external/

# Git worktrees (local development only)
worktrees/
# Gemini CLI settings (contains user-specific config)
.gemini/
Script.tar.gz
