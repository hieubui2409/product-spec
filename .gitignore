/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/dist/
bin/
.idea

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# package manager
package-lock.json
yarn.lock
pnpm-lock.yaml

# semantic-release
.nyc_output

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# flutter
.dart_tool
build
GoogleService-Info.plist

repomix-output.xml
.serena/cache
screenshots/*
docs/screenshots/*
logs.txt
test-ck
__pycache__

# CK meta commands
prompt.md
ck.md

# Generated runtime layout for release/install smoke tests.
# We ignore everything under /.claude/ EXCEPT:
#  - /.claude/rules/  : repo-level rules Claude Code reads
#  - /.claude/skills/product-spec/  : this repo's authored skill
/.claude/*
!/.claude/rules/
!/.claude/skills/
/.claude/skills/*
!/.claude/skills/product-spec/
!/.claude/skills/product-spec/**
!/.claude/skills/release/
!/.claude/skills/release/**
!/.claude/skills/product-spec-critique/
!/.claude/skills/product-spec-critique/**
# cleanmatic:telemetry — usage-&-health skill (git-tracked AND bundled: listed in
# pack.manifest.yaml skills:[]; its shared lens/eval code rides _include_shared).
!/.claude/skills/telemetry/
!/.claude/skills/telemetry/**
# Seed manifest for claude-pack (committed source-of-truth)
!/.claude/pack.manifest.yaml
# CK-framework artifacts committed so the repo self-packs reproducibly
!/.claude/agents/
!/.claude/agents/**
!/.claude/scripts/
!/.claude/scripts/**
!/.claude/schemas/
!/.claude/schemas/**
# /.claude/hooks/ holds ck-managed *.cjs (NOT this repo's) — keep them ignored.
# OUR hooks are Python; track every *.py here (memory_gap_hook,
# product_spec_critique_nudge, + the A1 telemetry hooks) and leave ck *.cjs ignored.
!/.claude/hooks/
/.claude/hooks/*
!/.claude/hooks/*.py
# Track the per-hook config too (not a *.py, so re-include it explicitly). The
# runtime crash log (.logs/hook-crashes.log) stays ignored via the /* rule above.
!/.claude/hooks/product-spec-hooks.json
# Re-ignore Python cache + build artifacts inside tracked skills
/.claude/skills/product-spec/**/__pycache__/
/.claude/skills/product-spec/**/*.pyc
/.claude/skills/release/**/__pycache__/
/.claude/skills/release/**/*.pyc
/.claude/skills/release/dist/
/.claude/skills/product-spec-critique/**/__pycache__/
/.claude/skills/product-spec-critique/**/*.pyc
/.claude/skills/product-spec-critique/**/.pytest_cache/
/.claude/skills/telemetry/**/__pycache__/
/.claude/skills/telemetry/**/*.pyc
/.claude/scripts/**/__pycache__/
/.claude/scripts/**/*.pyc

# Local-only state inside tracked claude source
claude/agent-memory/
/.claude/hooks/.logs/
claude/session-state/latest.md
claude/session-state/archive/
claude/settings.bak.json
claude/skills/ai-multimodal/assets/demo-*.claude/session-state/*.tmp

# Gemini CLI settings (symlink to staged .claude/.mcp.json)
.gemini/settings.json
# Showoff/marketing assets (images, showcases)
assets/
# Exception: use-mcp ships a persistent tool catalog at assets/tools.json
!claude/skills/use-mcp/assets/
!claude/skills/use-mcp/assets/**
# Exception: product-spec ships templates + vendored Mermaid JS in assets/
!.claude/skills/product-spec/assets/
!.claude/skills/product-spec/assets/**
# Exception: release ships installer templates + manifest example in assets/
!.claude/skills/release/assets/
!.claude/skills/release/assets/**

# External repos for study/reference
external/

# Git worktrees (local development only)
worktrees/
# Gemini CLI settings (contains user-specific config)
.gemini/
Script.tar.gz

# spec-critique e2e scratch bundles (transient agent scratch, not part of the fixture)
/e2e/**/.regen-bundle.json
/e2e/**/.regen-bundle-*.json
/e2e/**/.regen-lenses-*.json
/e2e/**/.critique-bundle-*.json

# ck-managed local artifact (regenerated by `ck init`; not part of this repo's source)
/release-manifest.json

# transient decision-register file lock (never committed)
**/.decision_register.lock

# --- A1 telemetry (observability) -------------------------------------------
# Sinks are runtime-only: never committed, never distributed. Created at runtime
# by telemetry_paths.py, so no tracked placeholder needed.
/.claude/telemetry/
# Telemetry tooling is CM-repo source (committed) AND bundled to recipients
# (the Python hooks are listed in pack.manifest hooks:[]). The hooks are re-included
# by the `!/.claude/hooks/*.py` rule above; their Python tests need re-including too
# (tests are git-tracked here but dropped from the bundle by safety_catalog).
!/.claude/hooks/__tests__/
/.claude/hooks/__tests__/*
!/.claude/hooks/__tests__/*.py
# Shared CM-owned lib (eval harness run_evals/llm_eval + telemetry_paths.py +
# register_telemetry_hooks.py + references). Track all of _shared EXCEPT the
# ck-managed *.cjs (e.g. plan-table-parser.cjs, used by ck plans-kanban /
# markdown-novel-viewer) and python caches.
!/.claude/skills/_shared/
!/.claude/skills/_shared/**
/.claude/skills/_shared/**/*.cjs
/.claude/skills/_shared/**/__pycache__/
/.claude/skills/_shared/**/*.pyc
/.claude/skills/_shared/**/.pytest_cache/
